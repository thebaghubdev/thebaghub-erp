PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

JWT_SECRET=change-me-in-production-use-long-random-string

# Cloudflare Turnstile — client signup (/api/auth/register/client). Set this and
# frontend/.env `VITE_TURNSTILE_SITE_KEY` (same widget’s site key + secret).
# https://developers.cloudflare.com/turnstile/get-started/server-side-validation/
TURNSTILE_SECRET_KEY=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=baghub
DB_PASSWORD=baghub
DB_DATABASE=baghub

# AWS S3 (consignment inquiry photos). Do not commit real keys — copy to .env locally.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# SMTP (client email verification). If MAIL_HOST is empty, new clients are marked
# verified without sending mail (local dev only — set these in production).
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=The Bag Hub

# After adding email verification, existing client rows need verification or they
# cannot sign in. Example backfill (run once in SQL):
# UPDATE users u SET email_verified_at = NOW(), email_verification_token = NULL,
#   email_verification_expires_at = NULL
# FROM clients c WHERE c.user_id = u.id AND u.user_type = 'client'
#   AND u.email_verified_at IS NULL;
